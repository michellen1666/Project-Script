# Board state & game logic
# =========================

class BingoBoard:
    def __init__(self, board_numbers: Optional[List[List[int]]] = None):
        if board_numbers is None:
            self.board = read_bingo_board()
        else:
            self.board = board_numbers

        self.marked = set()
        self.marked.add((2, 2))  # free center
        self.bingos_completed = 0

    def find_number(self, target: int) -> Optional[Tuple[int,int]]:
        for r in range(5):
            for c in range(5):
                if self.board[r][c] == target and (r, c) not in self.marked:
                    return (r, c)
        return None

    def mark_position(self, row: int, col: int):
        if (row, col) not in self.marked:
            self.marked.add((row, col))
            log(f"[BOARD] Marked ({row}, {col}) - Number: {self.board[row][col]}")

    def check_bingos(self) -> int:
        bingos = 0
        for r in range(5):
            if all((r, c) in self.marked for c in range(5)):
                bingos += 1
        for c in range(5):
            if all((r, c) in self.marked for r in range(5)):
                bingos += 1
        if all((i, i) in self.marked for i in range(5)):
            bingos += 1
        if all((i, 4 - i) in self.marked for i in range(5)):
            bingos += 1
        corners = [(0,0), (0,4), (4,0), (4,4)]
        if all((r, c) in self.marked for r, c in corners):
            bingos += 1
        return bingos

