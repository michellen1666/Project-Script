                if color_matches(prize_px, PRIZE_COLOR, tolerance=TOLERANCE):
                    log("[WATCHER] Prize Wheel detected - tapping to close/spin.")
                    d.click(*PRIZE_TAP)
                    time.sleep(1.0)
            except Exception:
                pass

            # --- Streak Break check - FIXED to loop through pixels ---
            try:
                for pixel_pos in STREAK_PIXELS:
