def match_number_centered(crop_gray, crop_bgr_for_debug=None, row=None, col=None):
    """
    OPTIMIZATION #3: Uses preprocessed templates.
    Improved matching with centering:
    - Center the crop around the number's centroid
    - Match against preprocessed grayscale templates
    - Use both grayscale and edge matching
    Returns (best_num, best_score)
    """
    best_num = None
    best_score = -1.0

    if not PREPROCESSED_TEMPLATES:
        return None, 0.0

    # Center the crop first
    crop_centered = recenter_crop(crop_gray, TARGET_SIZE)
    
    # Preprocess centered crop
    crop_proc = preprocess_for_matching(crop_centered)
    crop_edges = edges_for_matching(crop_proc)

    for num, tmpl_proc in PREPROCESSED_TEMPLATES.items():
        try:
            # Grayscale matching - template already preprocessed
            try:
                res_g = cv2.matchTemplate(crop_proc, tmpl_proc, cv2.TM_CCOEFF_NORMED)
                gscore = float(np.max(res_g))
            except Exception:
                gscore = -1.0
            
            # Edge matching - edges already computed
            try:
                tmpl_edges = TEMPLATE_EDGES[num]
                res_e = cv2.matchTemplate(crop_edges, tmpl_edges, cv2.TM_CCOEFF_NORMED)
                escore = float(np.max(res_e))
            except Exception:
                escore = -1.0
            
            # Combine scores: take the better (edges often help)
            combined = max(gscore, escore * 0.98)
            
            if combined > best_score:
                best_score = combined
                best_num = num
        
        except Exception as e:
            log(f"[WARN] match error for template #{num}: {e}")
            continue

    return best_num, best_score

# OPTIMIZATION #1: Parallel board reading
def read_bingo_board():
    """
    OPTIMIZATION #1: Reads the 5x5 bingo board with parallel template matching.
    Returns a 5x5 list of integers (0 for center star).
    """
    screenshot_cache.invalidate()
    img = screenshot_cache.get(force_refresh=True)
    
    def match_cell(row, col):
        """Match a single cell - can run in parallel"""
        if row == 2 and col == 2:
            return (row, col, 0)
        
        cx, cy = BOARD_POSITIONS[(row, col)]
        x1 = max(0, cx - CROP_HALF)
        y1 = max(0, cy - CROP_HALF)
        x2 = min(img.shape[1], cx + CROP_HALF)
        y2 = min(img.shape[0], cy + CROP_HALF)
        
        crop_bgr = img[y1:y2, x1:x2]
        gray = cv2.cvtColor(crop_bgr, cv2.COLOR_BGR2GRAY)
        
        num, score = match_number_centered(gray, crop_bgr, row, col)
        
        if num is None:
            log(f"[MATCH] ({row},{col}) => None (no templates) -> 0")
            return (row, col, 0)
        else:
            if score < BOARD_MATCH_CONFIDENCE_MIN:
                log(f"[LOW CONF] ({row},{col}) matched {num} with low score {score:.3f}")
            else:
                log(f"[MATCH] ({row},{col}) = {num} (score={score:.3f})")
            return (row, col, num)
    
    # Create all cell tasks
    tasks = [(r, c) for r in range(5) for c in range(5)]
    
    # Process in parallel with thread pool
    results = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=8) as executor:
        futures = [executor.submit(match_cell, r, c) for r, c in tasks]
        for future in concurrent.futures.as_completed(futures):
            results.append(future.result())
    
    # Sort results and build board
    results.sort(key=lambda x: (x[0], x[1]))
    board = [[0]*5 for _ in range(5)]
    for r, c, num in results:
        board[r][c] = num
    
    return board

