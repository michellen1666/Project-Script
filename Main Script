def load_dice_templates(template_dir: str = DICE_TEMPLATE_DIR):
    global DICE_TEMPLATES
    DICE_TEMPLATES.clear()
    for i in range(1, 7):
        fname = f"die_{i}.png"
        path = os.path.join(template_dir, fname)
        if os.path.exists(path):
            tmpl = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
            if tmpl is not None:
                DICE_TEMPLATES[i] = tmpl
            else:
                log(f"[WARN] Failed to load dice template: {path}")
        else:
            log(f"[WARN] Dice template missing: {path}")
    log(f"[TEMPLATES] Loaded {len(DICE_TEMPLATES)} dice templates from '{template_dir}'")

def load_board_templates(template_dir: str = BOARD_TEMPLATE_DIR):
    global BOARD_TEMPLATES
    BOARD_TEMPLATES.clear()
    if not os.path.exists(template_dir):
        log(f"[ERROR] Board template directory not found: {template_dir}")
        return
    for fname in sorted(os.listdir(template_dir)):
        if not fname.lower().endswith(".png"):
            continue
        name = fname[:-4]
        if not name.isdigit():
            continue
        num = int(name)
        path = os.path.join(template_dir, fname)
        tmpl = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
        if tmpl is None:
            log(f"[WARN] Could not load board template: {path}")
            continue
        BOARD_TEMPLATES[num] = tmpl
    log(f"[TEMPLATES] Loaded {len(BOARD_TEMPLATES)} board templates from '{template_dir}'")

