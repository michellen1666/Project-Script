# =========================

def find_number_centroid(crop_gray, debug=False):
    """
    Find the center of the number in the crop using contours.
    Returns (cx, cy) offset from crop origin, or None if not found.
    """
    # Threshold to isolate the number (adjust these values based on your images)
    _, thresh = cv2.threshold(crop_gray, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    
    # Try inverted threshold if needed
    _, thresh_inv = cv2.threshold(crop_gray, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    
    # Find contours in both versions
    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    contours_inv, _ = cv2.findContours(thresh_inv, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    
    # Use whichever gives better results (more mid-sized contours)
    all_contours = contours + contours_inv
    
    if not all_contours:
        return None
    
    # Filter contours by area (ignore too small/large)
    h, w = crop_gray.shape
    min_area = (h * w) * 0.05  # at least 5% of crop
    max_area = (h * w) * 0.8   # at most 80% of crop
    
    valid_contours = [c for c in all_contours 
                      if min_area < cv2.contourArea(c) < max_area]
    
    if not valid_contours:
        # Fallback: use image center
        return (w // 2, h // 2)
    
    # Find the largest valid contour (likely the number)
    largest = max(valid_contours, key=cv2.contourArea)
    
    # Get centroid using moments
    M = cv2.moments(largest)
    if M["m00"] == 0:
        return (w // 2, h // 2)
    
    cx = int(M["m10"] / M["m00"])
    cy = int(M["m01"] / M["m00"])
    
    if debug:
        debug_img = cv2.cvtColor(crop_gray, cv2.COLOR_GRAY2BGR)
        cv2.drawContours(debug_img, [largest], -1, (0, 255, 0), 2)
        cv2.circle(debug_img, (cx, cy), 5, (0, 0, 255), -1)
        cv2.imshow("Centroid Debug", debug_img)
        cv2.waitKey(0)
    
    return (cx, cy)

def recenter_crop(crop_gray, target_size=(100, 100)):
    """
    Recenter a crop around the number's centroid.
    Returns a centered crop of target_size.
    """
    centroid = find_number_centroid(crop_gray)
    
    if centroid is None:
        # Fallback: just resize the original crop
        return cv2.resize(crop_gray, target_size, interpolation=cv2.INTER_AREA)
    
    cx, cy = centroid

    
    # Calculate new crop bounds centered on the number
    half_w = target_size[0] // 2
    half_h = target_size[1] // 2
    
    x1 = cx - half_w
    y1 = cy - half_h
    x2 = cx + half_w
    y2 = cy + half_h
    
    # Handle boundaries with padding
    h, w = crop_gray.shape
    
    # Calculate padding needed
    pad_left = max(0, -x1)
    pad_top = max(0, -y1)
    pad_right = max(0, x2 - w)
    pad_bottom = max(0, y2 - h)
    
    # Adjust crop coordinates
    x1 = max(0, x1)
    y1 = max(0, y1)
    x2 = min(w, x2)
    y2 = min(h, y2)
    
    # Extract crop
    centered = crop_gray[y1:y2, x1:x2]
    
    # Add padding if needed (use median color)
    if pad_left > 0 or pad_top > 0 or pad_right > 0 or pad_bottom > 0:
        median_val = int(np.median(centered))
        centered = cv2.copyMakeBorder(
            centered, 
            pad_top, pad_bottom, pad_left, pad_right,
            cv2.BORDER_CONSTANT, 
            value=median_val
        )
    
    # Ensure exact target size
    if centered.shape != target_size:
        centered = cv2.resize(centered, target_size, interpolation=cv2.INTER_AREA)
    
    return centered

