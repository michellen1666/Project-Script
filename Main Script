    STREAK_COLOR = (251, 240, 254)
    STREAK_TAP = (605, 1674)

    TOLERANCE = 10
    INTERVAL = 0.5

    log("[WATCHER] Popup watcher started")
    while True:
        try:
            img = d.screenshot(format="opencv")

