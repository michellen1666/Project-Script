def detect_dice_fast(max_retries=2) -> Tuple[List[int], List[Tuple[int, int]]]:
    """
    OPTIMIZATION #6: Detect dice only in the known dice region (ROI).
    Faster than full-screen template matching.
    Auto-retries if any dice show 0 (detection failure).
    
    Args:
        max_retries: Number of retry attempts if zeros detected
    
    Returns: (values_list, coords_list)
    Sorted left->right, padded to 3 elements.
    """
    attempt = 0
    
    while attempt <= max_retries:
        if attempt > 0:
            screenshot_cache.invalidate()
            time.sleep(1.0)  # Wait before retry
        
        img = screenshot_cache.get(force_refresh=(attempt > 0))
        x1, y1, x2, y2 = DICE_ROI
        roi = img[y1:y2, x1:x2]
        gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)

        detected: List[Tuple[int,int,int]] = []

        for value, tmpl in DICE_TEMPLATES.items():
            if tmpl is None:
                continue
            try:
                res = cv2.matchTemplate(gray, tmpl, cv2.TM_CCOEFF_NORMED)
                loc = np.where(res >= TEMPLATE_MATCH_THRESHOLD)
                for pt in zip(*loc[::-1]):
                    x, y = int(pt[0]) + x1, int(pt[1]) + y1  # Adjust for ROI offset
                    # suppress duplicates (nearby detections)
                    duplicate = False
                    for _, ex, ey in detected:
                        if abs(x - ex) < 60 and abs(y - ey) < 60:
                            duplicate = True
                            break
                    if duplicate:
                        continue
                    detected.append((value, x, y))
            except Exception as e:
                log(f"[WARN] Dice template match failed for die_{value}: {e}")

        detected.sort(key=lambda t: t[1])  # sort by x
        
        values = [v for v, x, y in detected]
        coords = [(x, y) for v, x, y in detected]
        
        # Pad to 3
        while len(values) < 3:
            values.append(0)
            coords.append((0, 0))
        
        # Check if any dice are 0 (detection failed)
        if 0 in values and attempt < max_retries:
            zero_count = values.count(0)
            log(f"[DICE] Detected {zero_count} zero(s) on attempt {attempt + 1}/{max_retries + 1} - retrying in 1 second...")
            attempt += 1
            continue
        
        # Success or max retries reached
        if 0 in values:
            zero_count = values.count(0)
            log(f"[DICE] Still detected {zero_count} zero(s) after {max_retries} retries")
        
        log(f"[DICE] Detected values: {values[:3]} | coords: {coords[:3]}")
        return values[:3], coords[:3]
    
    # Fallback
    return values[:3], coords[:3]

