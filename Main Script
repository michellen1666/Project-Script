def play_game():
    log("[INFO] Starting Optimized Bingo Dice Game Bot")
    board = BingoBoard()
    roll_dice()
    turn_count = 0

    while True:
        turn_count += 1
        log(f"[INFO] === Turn {turn_count} ===")
        time.sleep(0.2)  # Increased - let UI fully settle

        # OPTIMIZED: Single detection call returns both values and coords
        try:
            dice, coords = detect_dice_fast()
        except RuntimeError:
            log("[FATAL] Dice detection failed — restarting app immediately.")
            force_close_app()
            restart_app()
            press_play_turn_button()
            board = BingoBoard()
            roll_dice()
            turn_count = 0
            continue

        # If detect_dice_fast somehow returned zeros without raising, handle gracefully
        if all(dv == 0 for dv in dice):
            log("[WARN] No dice detected - retrying...")
            time.sleep(1.0)  # Increased significantly
            dice, coords = detect_dice_fast()
            if all(dv == 0 for dv in dice):
                log("[WARN] Still no dice - attempting reroll/pass")
                if should_reroll():
                    log("[INFO] Rerolling")
                    roll_dice()
                    time.sleep(0.8)  # Increased
                    dice, coords = detect_dice_fast()
                    if all(dv == 0 for dv in dice):
                        log("[INFO] No dice after reroll - pass")
                        pass_turn()
                        wait_for_your_turn()
                        roll_dice()
                        continue
                else:
                    log("[INFO] Can't reroll - passing")
                    pass_turn()
                    wait_for_your_turn()
                    roll_dice()
                    continue

        best_move = find_best_move(dice, board)
        if best_move is None:
            log("[INFO] No valid move - passing")
            pass_turn()
            wait_for_your_turn()
            roll_dice()
            continue

        number, dice_indices, board_pos = best_move
        log(f"[ACTION] Playing {number} at {board_pos}")

        # OPTIMIZED: Pass detected values and coords to avoid re-detection
        play_move(dice, coords, dice_indices, board_pos, number)
        time.sleep(0.5)
        board.mark_position(*board_pos)

        bingos = board.check_bingos()
        if bingos > board.bingos_completed:
            log(f"[BINGO!] Completed {bingos} bingo(s)!")
            board.bingos_completed = bingos

        if board.bingos_completed >= 3 or check_game_over():
            handle_game_end()
            board = BingoBoard()
            roll_dice()
            turn_count = 0
            continue

        time.sleep(0.8)  # Increased
        log("[INFO] Rolling dice for next turn")
        roll_dice()

