class ScreenshotCache:
    def __init__(self, ttl=0.5):  # Increased TTL for better stability
        self.cache = None
        self.timestamp = 0
        self.ttl = ttl
    
    def get(self, force_refresh=False):
        current_time = time.time()
        if force_refresh or self.cache is None or (current_time - self.timestamp) > self.ttl:
            self.cache = d.screenshot(format="opencv")
            self.timestamp = current_time
            time.sleep(GLOBAL_SCREENSHOT_DELAY)
        return self.cache
    
    def invalidate(self):
        self.cache = None

# Initialize global cache with more conservative TTL
