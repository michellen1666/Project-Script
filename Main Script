# OPTIMIZED: wait_for_your_turn using batch conditions check
def wait_for_your_turn():
    log("[INFO] Waiting for opponent to finish their turn...")
    start_time = time.time()
    max_wait = 120
    waiting_text_gone_count = 0
    TESTING_MODE = True
    check_interval = 1.0 if TESTING_MODE else 0.8  # Slower polling
    fallback_threshold = 15 if TESTING_MODE else 5  # More checks before assuming turn
    
    # Initial wait before checking - give opponent time to start
    time.sleep(1.0)  # Increased significantly

    while True:
        if time.time() - start_time > max_wait:
            log("[WARN] Opponent turn timeout - assuming it's our turn")
            break
        
        screenshot_cache.invalidate()
        img = screenshot_cache.get(force_refresh=True)
        
        # OPTIMIZATION #5: Use batch condition checking
        conditions = check_multiple_conditions(img)
        
        try:
            if not conditions['opponent_turn']:
                waiting_text_gone_count += 1
                if conditions['your_turn']:
                    log("[INFO] Your turn detected - roll button green")
                    break
                else:
                    log(f"[DEBUG] Waiting text gone but roll not green yet (count: {waiting_text_gone_count}/{fallback_threshold})")
                    if waiting_text_gone_count >= fallback_threshold:
                        log(f"[INFO] Text gone long enough - assuming your turn")
                        time.sleep(1.0)  # Increased significantly
                        break
            else:
                waiting_text_gone_count = 0
        except Exception as e:
            log(f"[DEBUG] Error checking turn state: {e}")
        time.sleep(check_interval)
    log("[INFO] Opponent turn complete")

def handle_game_end():
    log("[INFO] ===== GAME ENDED =====")
