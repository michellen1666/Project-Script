def force_restart_game():
    """Force restart the game after turn limit reached."""
    log("[INFO] ===== TURN LIMIT REACHED - FORCE RESTARTING APP =====")
    
    # Force stop the app
    try:
        log("[INFO] Force stopping app...")
        d.app_stop(APP_PACKAGE)
        time.sleep(3.0)
        log("[INFO] App stopped successfully")
    except Exception as e:
