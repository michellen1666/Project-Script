def generate_combinations(dice: List[int]) -> List[Tuple[int, List[int]]]:
    """
    Generate all possible number combinations from the dice.
    Returns list of (number, [dice_indices_used])
    """
    combos: List[Tuple[int, List[int]]] = []
    
    # Single dice
    for i, v in enumerate(dice):
        if v > 0:
            combos.append((v, [i]))
    
    # Two dice combinations
    for i in range(len(dice)):
        for j in range(i+1, len(dice)):
            if dice[i] > 0 and dice[j] > 0:
                # dice[i] followed by dice[j]
                combos.append((dice[i]*10 + dice[j], [i, j]))
                # dice[j] followed by dice[i]
                combos.append((dice[j]*10 + dice[i], [j, i]))
    
    return combos

def find_best_move(dice: List[int], board: BingoBoard) -> Optional[Tuple[int, List[int], Tuple[int,int]]]:
    combos = generate_combinations(dice)
    valid = []
    for num, dice_idx in combos:
        pos = board.find_number(num)
        if pos is not None:
            valid.append((num, dice_idx, pos))
    if not valid:
        return None

    def score_move(m):
        num, dice_idx, (r, c) = m
        score = 0
        test_marked = set(board.marked)
        test_marked.add((r, c))
        if all((r, cc) in test_marked for cc in range(5)): score += 1000
        if all((rr, c) in test_marked for rr in range(5)): score += 1000
        if r == c and all((i, i) in test_marked for i in range(5)): score += 1000
        if r + c == 4 and all((i, 4-i) in test_marked for i in range(5)): score += 1000
        lines = 2
        if r == c: lines += 1
        if r + c == 4: lines += 1
        score += lines * 10
        score += (3 - len(dice_idx)) * 5
        return score

    valid.sort(key=score_move, reverse=True)
    return valid[0]

# OPTIMIZED BUT CORRECT: play_move - Re-detect only when needed
def play_move(dice_values: List[int], dice_coords: List[Tuple[int,int]], dice_indices: List[int], 
              board_position: Tuple[int,int], target_number: int):
    log(f"[MOVE] Starting move: dice indices {dice_indices} -> number {target_number}")
    log(f"[MOVE] Need dice values: {[dice_values[i] for i in dice_indices]}")
    
    # If only one die, use pre-detected coords (optimization still works)
    if len(dice_indices) == 1:
        i = dice_indices[0]
        if i < len(dice_coords) and dice_coords[i] != (0, 0):
            x, y = dice_coords[i]
            d.click(x + 10, y + 10)
            log(f"[TAP] Die {dice_values[i]} at ({x+10}, {y+10})")
    
    # If multiple dice, we need to re-detect after first tap (dice move)
    else:
        for tap_num, die_index in enumerate(dice_indices):
            target_value = dice_values[die_index]
            
            # First die: use pre-detected coords (optimization)
            if tap_num == 0:
                if die_index < len(dice_coords) and dice_coords[die_index] != (0, 0):
                    x, y = dice_coords[die_index]
                    d.click(x + 10, y + 10)
                    log(f"[TAP] Die {target_value} at ({x+10}, {y+10})")
                    time.sleep(0.4)  # Wait for die to animate
            
            # Subsequent dice: re-detect to find untapped dice
            else:
                log(f"[MOVE] Re-detecting for die with value {target_value}")
                screenshot_cache.invalidate()
                time.sleep(0.3)
                current_dice_vals, current_dice_coords = detect_dice_fast()
                
                # Find untapped die with target value (y > 1800 means untapped)
                target_die = None
                for val, (x, y) in zip(current_dice_vals, current_dice_coords):
                    if val == target_value and y > 1800:
                        target_die = (val, x, y)
                        break
                
                if target_die:
                    val, x, y = target_die
                    d.click(x + 10, y + 10)
                    log(f"[TAP] Die {val} at ({x+10}, {y+10})")
                    if tap_num < len(dice_indices) - 1:
                        time.sleep(0.6)
                else:
                    log(f"[WARN] Could not find untapped die with value {target_value}")
    
    # Wait for all dice selections to register
    time.sleep(.8)
    
    # Tap board position
    pos = BOARD_POSITIONS[board_position]
    time.sleep(0.5)
    d.click(*pos)
    log(f"[TAP] Board position {board_position} (number {target_number}) at {pos}")
    time.sleep(2.5)
    
    # Invalidate cache since board state changed
    screenshot_cache.invalidate()
    
    # Give UI time to process the move and transition
    time.sleep(1.5)
    log("[MOVE] Move submitted")
    wait_for_your_turn()
    log("[MOVE] Move complete")

