def preprocess_for_matching(img_gray):
    """
    Apply CLAHE (local histogram equalization) and slight blur to reduce lighting/noise.
    """
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
    eq = clahe.apply(img_gray)
    eq = cv2.GaussianBlur(eq, (3,3), 0)
    return eq

def is_continue_screen(img):
    pixel = get_pixel(img, CONTINUE_PIXEL)
    return color_matches(pixel, CONTINUE_COLOR, tolerance=40)

def edges_for_matching(img_gray):
    """
    Return a dilated Canny edge image tuned by the median of the image.
    """
    med = np.median(img_gray)
    lower = int(max(1, 0.66 * med))
    upper = int(min(254, 1.33 * med))
    edges = cv2.Canny(img_gray, lower, upper)
    edges = cv2.dilate(edges, np.ones((3,3), np.uint8), iterations=1)
    return edges

def log(msg: str):
    print(f"[LOG] {msg}")

def color_matches(pixel: Tuple[int,int,int], target: Tuple[int,int,int], tolerance: int = PIXEL_TOLERANCE):
    return all(abs(int(p) - int(t)) <= tolerance for p, t in zip(pixel, target))

def get_pixel(img, coord: Tuple[int,int]):
    bgr = img[coord[1], coord[0]]
    return tuple(int(c) for c in bgr[::-1])

