def check_multiple_conditions(img=None) -> Dict[str, bool]:
    """
    OPTIMIZATION #5: Check multiple UI conditions with a single screenshot.
    Returns dict of all conditions at once.
    """
    if img is None:
        img = screenshot_cache.get()
    
    conditions = {
        'should_reroll': False,
        'game_over': False,
        'your_turn': False,
        'opponent_turn': False
    }
    
    try:
        # Check reroll button
        pixel = get_pixel(img, ROLL_BUTTON)
        conditions['should_reroll'] = color_matches(pixel, FREE_REROLL_COLOR, tolerance=30)
        
        # Check game over
        pixel = get_pixel(img, CLAIM_BUTTON_PIXEL)
        conditions['game_over'] = color_matches(pixel, CLAIM_BUTTON_COLOR, tolerance=30)
        
        # Check turn indicators
        pixel = get_pixel(img, YOUR_TURN_PIXEL)
        conditions['your_turn'] = color_matches(pixel, YOUR_TURN_COLOR, tolerance=40)
        
        pixel = get_pixel(img, OPPONENT_TURN_TEXT_PIXEL)
        conditions['opponent_turn'] = color_matches(pixel, OPPONENT_TURN_TEXT_COLOR, tolerance=30)
    except Exception as e:
        log(f"[DEBUG] Error checking conditions: {e}")
    
    return conditions

